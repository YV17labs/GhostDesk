FROM ubuntu:24.04

LABEL org.opencontainers.image.title="ghostdesk" \
      org.opencontainers.image.description="MCP server to control a virtual Linux desktop from an LLM agent" \
      org.opencontainers.image.authors="Yoann Vanitou <yvanitou@gmail.com>" \
      org.opencontainers.image.source="https://github.com/yv17labs/ghostdesk" \
      org.opencontainers.image.licenses="AGPL-3.0-only"

ENV DEBIAN_FRONTEND=noninteractive \
    DISPLAY=:99 \
    SCREEN_WIDTH=1280 \
    SCREEN_HEIGHT=1024 \
    SCREEN_DEPTH=24 \
    PORT=3000 \
    TZ=UTC \
    LOCALE=en_US.utf8 \
    RUN_USER=agent \
    APP_DIR=/app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        xvfb openbox tint2 x11vnc novnc websockify \
        xdotool maim xclip hsetroot x11-utils adwaita-icon-theme-full \
        locales \
        supervisor \
        dbus-x11 gnome-keyring libsecret-1-0 \
        libgl1 libglib2.0-0 \
        tzdata \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash agent

COPY --from=ghcr.io/astral-sh/uv:0.11 /uv /usr/local/bin/uv

# Dependencies first, source after — cache-friendly ordering
WORKDIR /app
COPY pyproject.toml uv.lock README.md ./
RUN chown -R agent:agent /app
USER agent
RUN uv sync --no-dev
USER root

COPY --chown=agent:agent src/ ./src/

COPY .docker/supervisor.conf /etc/supervisor/conf.d/ghostdesk.conf
COPY .docker/shared/start-openbox.sh /usr/local/bin/start-openbox.sh
COPY .docker/shared/init-container.sh /usr/local/bin/init-container.sh
COPY .docker/shared/entrypoint.sh /usr/local/bin/entrypoint.sh
COPY assets/wallpaper_1280x1024.png /usr/share/ghostdesk/wallpaper.png
COPY .docker/shared/tint2rc /usr/share/ghostdesk/tint2rc
RUN mkdir -p /home/agent/.config/openbox /home/agent/.config/tint2 \
    && printf '<?xml version="1.0" encoding="UTF-8"?>\n<openbox_config xmlns="http://openbox.org/3.4/rc">\n  <applications>\n    <application class="*"><decor>no</decor></application>\n  </applications>\n</openbox_config>\n' > /home/agent/.config/openbox/rc.xml \
    && cp /usr/share/ghostdesk/tint2rc /home/agent/.config/tint2/tint2rc \
    && chown -R agent:agent /home/agent/.config

EXPOSE 3000 5900 6080

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD supervisorctl status | grep -qv FATAL || exit 1

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
