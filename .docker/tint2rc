# tint2 config — GhostDesk taskbar
# Minimal dark panel: task list + clock

# Panel
panel_monitor = all
panel_position = bottom center horizontal
panel_size = 100% 32
panel_margin = 0 0
panel_padding = 4 0 4
panel_background_id = 1
panel_items = T SC
panel_dock = 0
panel_layer = top

# Backgrounds
# ID 1 — panel background
rounded = 0
border_width = 0
border_sides = T
background_color = #1A1B2E 95
border_color = #7B6FDE 40

# ID 2 — active task
rounded = 4
border_width = 1
background_color = #7B6FDE 40
border_color = #7B6FDE 60

# ID 3 — default task
rounded = 4
border_width = 0
background_color = #000000 0
border_color = #000000 0

# ID 4 — urgent task
rounded = 4
border_width = 1
background_color = #5DCAA5 40
border_color = #5DCAA5 60

# Taskbar
taskbar_mode = single_desktop
taskbar_padding = 2 2 4
taskbar_background_id = 0
taskbar_active_background_id = 0

# Tasks
task_text = 1
task_icon = 1
task_centered = 0
task_maximum_size = 200 28
task_padding = 6 2 6
task_font = sans 10
task_font_color = #E8E6FF 80
task_icon_size = 16
task_background_id = 3
task_active_background_id = 2
task_urgent_background_id = 4
task_active_font_color = #E8E6FF 100

# System tray
systray_padding = 4 2 4
systray_icon_size = 16
systray_background_id = 0

# Clock
time1_format = %H:%M
time1_font = sans bold 10
time2_format = %a %d %b
time2_font = sans 8
clock_font_color = #E8E6FF 80
clock_padding = 8 0
clock_background_id = 0
